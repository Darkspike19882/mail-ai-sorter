{
  "templates": {
    "basic": {
      "name": "Allrounder (Empfohlen)",
      "description": "Perfekt für die meisten User - privat und beruflich",
      "icon": "🎯",
      "target_users": ["privat", "beruflich", "familie", "studenten"],
      "popular_categories": ["finanzen", "shopping", "arbeit", "reisen", "newsletter"],
      "rules": [
        {
          "name": "Apple Regeln",
          "if_from_contains": ["apple.com", "icloud.com", "id.apple.com"],
          "move_to": "apple"
        },
        {
          "name": "Finanzen Regeln",
          "if_from_contains": ["paypal", "sparkasse", "volksbank", "commerzbank", "dkb", "n26", "visa", "mastercard"],
          "move_to": "finanzen"
        },
        {
          "name": "Shopping Regeln",
          "if_from_contains": ["amazon", "ebay", "dhl", "dpd", "amazon.de"],
          "move_to": "einkauf"
        },
        {
          "name": "Rechnungen automatisch erkennen",
          "if_subject_contains": ["rechnung", "beleg", "invoice", "receipt"],
          "move_to": "paperless"
        },
        {
          "name": "Newsletter erkennen",
          "if_subject_contains": ["newsletter", "unsubscribe", "abbestellen"],
          "move_to": "newsletter"
        }
      ],
      "important_rules": [
        {
          "name": "Wichtige Finanz-Behörden",
          "if_from_contains": ["finanzamt", "arbeitsagentur", "bund.de"],
          "if_subject_contains": ["wichtig", "frist", "bescheid"]
        }
      ]
    },
