{
  "global": {
    "ollama_url": "http://127.0.0.1:11434",
    "model": "gemma4:e4b",
    "delay_minutes": 30,
    "poll_minutes": 5,
    "max_body_chars": 5000,
    "default_category": "privat",
    "categories": [
      "paperless",
      "apple",
      "finanzen",
      "vertraege",
      "einkauf",
      "reisen",
      "arbeit",
      "behoerden",
      "newsletter",
      "privat"
    ],
    "telegram": {
      "bot_token_env": "TELEGRAM_BOT_TOKEN",
      "allowed_users_env": "TELEGRAM_ALLOWED_USERS",
      "max_results": 10
    },
    "extensions": {
      "enabled": false,
      "paperless_enabled": false,
      "paperless_url": "http://localhost:8000",
      "paperless_api_token": "",
      "calendar_enabled": false,
      "tasks_enabled": false,
      "task_system": "taskwarrior",
      "notifications_enabled": false,
      "notification_categories": ["arbeit", "finanzen", "behoerden"]
    }
  },
  "accounts": [
    {
      "name": "Beispiel Konto (Gmail) - Bitte eigene Daten eintragen",
      "imap_host": "imap.gmail.com",
      "imap_port": 993,
      "username": "deine.email@gmail.com",
      "password_env": "GMAIL_PASSWORD",
      "smtp_host": "smtp.gmail.com",
      "smtp_port": 587,
      "smtp_encryption": "starttls",
      "smtp_password_env": "GMAIL_PASSWORD",
      "from_name": "Dein Name",
      "source_folder": "INBOX",
      "target_folders": {
        "paperless": "Paperless",
        "apple": "Apple",
        "finanzen": "Finanzen",
        "vertraege": "Vertraege",
        "einkauf": "Einkauf",
        "reisen": "Reisen",
        "arbeit": "Arbeit",
        "behoerden": "Behoerden",
        "newsletter": "Newsletter",
        "privat": "Privat"
      },
      "rules": []
    }
  ]
}
