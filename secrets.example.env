# Beispiel für secrets.env - NICHT committen!
# Kopiere diese Datei als secrets.env und trage deine echten Passwörter ein

# Gmail Account
export GMAIL_PASSWORD="dein-app-passwort-hier"

# GMX Account
export GMX_PASSWORD="dein-passwort-hier"

# iCloud Account
export ICLOUD_PASSWORD="dein-app-passwort-hier"

# Eigener Server
export SERVER_PASSWORD="dein-passwort-hier"
